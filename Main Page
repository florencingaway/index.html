<!doctype html>
<html lang="en" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Happy Birthday Ashwa Sayang 🌸</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&amp;family=Quicksand:wght@400;500;600;700&amp;display=swap" rel="stylesheet">
  <style>
    @keyframes float {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50% { transform: translateY(-20px) rotate(5deg); }
    }
    @keyframes floatReverse {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50% { transform: translateY(-15px) rotate(-5deg); }
    }
    @keyframes petal-fall {
      0% { transform: translateY(-10%) rotate(0deg); opacity: 1; }
      100% { transform: translateY(110%) rotate(720deg); opacity: 0.3; }
    }
    @keyframes pop-in {
      0% { transform: scale(0) rotate(-10deg); opacity: 0; }
      60% { transform: scale(1.2) rotate(3deg); opacity: 1; }
      100% { transform: scale(1) rotate(0deg); opacity: 1; }
    }
    @keyframes wiggle {
      0%, 100% { transform: rotate(-3deg); }
      50% { transform: rotate(3deg); }
    }
    @keyframes sparkle {
      0%, 100% { opacity: 0; transform: scale(0); }
      50% { opacity: 1; transform: scale(1); }
    }
    @keyframes countdown-pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.05); }
    }
    @keyframes heart-burst {
      0% { transform: scale(0); opacity: 1; }
      50% { transform: scale(1.5); opacity: 0.8; }
      100% { transform: scale(0); opacity: 0; }
    }
    .float-anim { animation: float 4s ease-in-out infinite; }
    .float-anim-reverse { animation: floatReverse 3.5s ease-in-out infinite; }
    .pop-in { animation: pop-in 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
    .wiggle { animation: wiggle 1s ease-in-out infinite; }
    .countdown-pulse { animation: countdown-pulse 2s ease-in-out infinite; }
    .petal {
      position: absolute;
      animation: petal-fall linear forwards;
      pointer-events: none;
    }
    .sparkle-dot {
      position: absolute;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      animation: sparkle 2s ease-in-out infinite;
    }
    .heart-pop {
      position: absolute;
      animation: heart-burst 1s ease-out forwards;
      pointer-events: none;
    }
    .flower-btn {
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .flower-btn:hover {
      transform: scale(1.1) rotate(5deg);
    }
    .flower-btn:active {
      transform: scale(0.95);
    }
    .section-reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .section-reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .garden-flower {
      cursor: pointer;
      transition: transform 0.3s ease;
    }
    .garden-flower:hover {
      transform: scale(1.3) rotate(15deg);
    }
  </style>
  <style>body { box-sizing: border-box; }</style>
  <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
 <script src="/_sdk/telemetry_sdk.js"></script></head>
 <body class="h-full">
  <div id="app" class="w-full h-full overflow-auto" style="background: linear-gradient(180deg, #FFF5F7 0%, #FFFBEB 30%, #F0FFF4 60%, #FFF5F7 100%); font-family: 'Quicksand', sans-serif;"><!-- Falling Petals Container -->
   <div id="petals-container" class="fixed inset-0 pointer-events-none overflow-hidden" style="z-index: 1;"></div><!-- Sparkles -->
   <div id="sparkles-container" class="fixed inset-0 pointer-events-none" style="z-index: 2;"></div><!-- Hero Section -->
   <section class="relative flex flex-col items-center justify-center text-center px-6 py-20" style="min-height: 100%;">
    <div class="relative z-10"><!-- Floating flowers around title -->
     <div class="absolute -top-16 -left-12 text-5xl float-anim" style="animation-delay: 0s;">
      🌸
     </div>
     <div class="absolute -top-10 -right-10 text-4xl float-anim-reverse" style="animation-delay: 0.5s;">
      🌼
     </div>
     <div class="absolute -bottom-12 -left-8 text-4xl float-anim" style="animation-delay: 1s;">
      🌷
     </div>
     <div class="absolute -bottom-10 -right-12 text-5xl float-anim-reverse" style="animation-delay: 1.5s;">
      🌺
     </div>
     <p class="text-lg mb-3" style="color: #E8A0BF; font-weight: 600; letter-spacing: 2px;">✿ JUNE 8TH, 2026 ✿</p>
     <h1 id="main-title" class="text-5xl md:text-7xl font-black mb-4" style="font-family: 'Playfair Display', serif; color: #D4678E; text-shadow: 2px 2px 0px rgba(255,200,100,0.3);">Happy Birthday!</h1>
     <h2 id="pet-name" class="text-3xl md:text-5xl font-bold mb-8" style="font-family: 'Playfair Display', serif; color: #F5A623;">Ashwa Sayang 💛</h2>
     <p id="birthday-message" class="text-lg md:text-xl max-w-lg mx-auto mb-10" style="color: #7B8F6B; line-height: 1.8;">This little corner of the internet was made just for you, because you deserve all the flowers in the world 🌻</p><!-- Interactive Button --> <button id="surprise-btn" class="flower-btn px-8 py-4 rounded-full text-white font-bold text-lg shadow-lg" style="background: linear-gradient(135deg, #FFB6C1, #F5A623); box-shadow: 0 8px 30px rgba(245,166,35,0.3);" onclick="triggerSurprise()"> 🌸 Click for a Surprise! 🌸 </button>
    </div><!-- Countdown -->
    <div id="countdown-section" class="mt-16 countdown-pulse">
     <p class="text-sm font-semibold mb-3" style="color: #E8A0BF; letter-spacing: 1px;">COUNTDOWN TO THE BIG DAY</p>
     <div id="countdown" class="flex gap-4 justify-center flex-wrap"></div>
    </div>
   </section><!-- Signed Message -->
   <section class="relative py-12 px-6">
    <div class="max-w-lg mx-auto text-center">
     <p class="text-sm md:text-base font-medium italic" style="color: #D4678E; letter-spacing: 1px;">~ Sincerely, from a flower 🌸 ~</p>
    </div>
   </section><!-- Interactive Flower Garden -->
   <section class="relative py-20 px-6 section-reveal" id="garden-section">
    <div class="max-w-2xl mx-auto text-center">
     <h3 class="text-3xl font-bold mb-3" style="font-family: 'Playfair Display', serif; color: #D4678E;">Your Flower Garden 🌿</h3>
     <p class="mb-8" style="color: #7B8F6B;">Tap the flowers to make them bloom! Each one has a message for you~</p>
     <div id="flower-garden" class="grid grid-cols-3 md:grid-cols-5 gap-6 justify-items-center"></div>
     <div id="flower-message" class="mt-8 p-6 rounded-2xl opacity-0 transition-all duration-500" style="background: rgba(255,255,255,0.7); backdrop-filter: blur(10px);">
      <p class="text-lg font-medium" style="color: #D4678E;"></p>
     </div>
    </div>
   </section><!-- Fun Facts / Wishes -->
   <section class="relative py-20 px-6 section-reveal" id="wishes-section">
    <div class="max-w-lg mx-auto text-center">
     <h3 class="text-3xl font-bold mb-8" style="font-family: 'Playfair Display', serif; color: #F5A623;">Birthday Wishes 🎂</h3>
     <div id="wish-cards" class="space-y-4"></div>
    </div>
   </section><!-- Heart Click Area -->
   <section class="relative py-20 px-6 section-reveal" id="heart-section">
    <div class="max-w-lg mx-auto text-center">
     <h3 class="text-3xl font-bold mb-4" style="font-family: 'Playfair Display', serif; color: #D4678E;">Love Counter 💕</h3>
     <p class="mb-6" style="color: #7B8F6B;">Tap the heart to send love!</p>
     <div class="relative inline-block"><button id="heart-btn" class="text-7xl transition-transform duration-200 hover:scale-110 active:scale-90" onclick="sendLove()">💖</button>
      <p id="love-count" class="mt-4 text-2xl font-bold" style="color: #E8A0BF;">0 loves sent</p>
      <div id="hearts-fly" class="absolute inset-0 pointer-events-none"></div>
     </div>
    </div>
   </section><!-- Footer -->
   <footer class="py-12 text-center px-6">
    <p class="text-lg font-semibold" style="color: #D4678E;">Made with 💛 for the most amazing person</p>
    <p class="mt-2 text-3xl wiggle">🌸🌼🌷🌻🌺</p>
   </footer>
  </div>
  <script>
  // Config & SDK
  const defaultConfig = {
    main_title: "Happy Birthday!",
    pet_name: "Ashwa Sayang 💛",
    birthday_message: "This little corner of the internet was made just for you, because you deserve all the flowers in the world 🌻",
    background_color: "#FFF5F7",
    surface_color: "#FFFFFF",
    text_color: "#7B8F6B",
    primary_color: "#D4678E",
    secondary_color: "#F5A623"
  };

  function applyConfig(config) {
    const c = { ...defaultConfig, ...config };
    document.getElementById('main-title').textContent = c.main_title;
    document.getElementById('pet-name').textContent = c.pet_name;
    document.getElementById('birthday-message').textContent = c.birthday_message;

    document.getElementById('main-title').style.color = c.primary_color;
    document.getElementById('pet-name').style.color = c.secondary_color;
    document.getElementById('birthday-message').style.color = c.text_color;

    document.querySelectorAll('.section-reveal h3').forEach((h, i) => {
      h.style.color = i % 2 === 0 ? c.primary_color : c.secondary_color;
    });
  }

  window.elementSdk.init({
    defaultConfig,
    onConfigChange: async (config) => applyConfig(config),
    mapToCapabilities: (config) => ({
      recolorables: [
        { get: () => config.background_color || defaultConfig.background_color, set: (v) => { config.background_color = v; window.elementSdk.setConfig({ background_color: v }); }},
        { get: () => config.surface_color || defaultConfig.surface_color, set: (v) => { config.surface_color = v; window.elementSdk.setConfig({ surface_color: v }); }},
        { get: () => config.text_color || defaultConfig.text_color, set: (v) => { config.text_color = v; window.elementSdk.setConfig({ text_color: v }); }},
        { get: () => config.primary_color || defaultConfig.primary_color, set: (v) => { config.primary_color = v; window.elementSdk.setConfig({ primary_color: v }); }},
        { get: () => config.secondary_color || defaultConfig.secondary_color, set: (v) => { config.secondary_color = v; window.elementSdk.setConfig({ secondary_color: v }); }}
      ],
      borderables: [],
      fontEditable: {
        get: () => config.font_family || 'Quicksand',
        set: (v) => { config.font_family = v; window.elementSdk.setConfig({ font_family: v }); }
      },
      fontSizeable: {
        get: () => config.font_size || 16,
        set: (v) => { config.font_size = v; window.elementSdk.setConfig({ font_size: v }); }
      }
    }),
    mapToEditPanelValues: (config) => new Map([
      ["main_title", config.main_title || defaultConfig.main_title],
      ["pet_name", config.pet_name || defaultConfig.pet_name],
      ["birthday_message", config.birthday_message || defaultConfig.birthday_message]
    ])
  });

  // Countdown
  function updateCountdown() {
    const birthday = new Date('2026-06-08T00:00:00');
    const now = new Date();
    const diff = birthday - now;

    if (diff <= 0) {
      document.getElementById('countdown').innerHTML = '<p class="text-2xl font-bold" style="color: #D4678E;">🎉 IT\'S TODAY! HAPPY BIRTHDAY! 🎉</p>';
      return;
    }

    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const secs = Math.floor((diff % (1000 * 60)) / 1000);

    const units = [
      { val: days, label: 'Days' },
      { val: hours, label: 'Hours' },
      { val: mins, label: 'Mins' },
      { val: secs, label: 'Secs' }
    ];

    document.getElementById('countdown').innerHTML = units.map(u => `
      <div class="flex flex-col items-center px-4 py-3 rounded-xl" style="background: rgba(255,255,255,0.7); backdrop-filter: blur(5px); min-width: 70px;">
        <span class="text-2xl md:text-3xl font-black" style="color: #D4678E;">${u.val}</span>
        <span class="text-xs font-semibold" style="color: #F5A623;">${u.label}</span>
      </div>
    `).join('');
  }
  updateCountdown();
  setInterval(updateCountdown, 1000);

  // Falling Petals
  function createPetal() {
    const container = document.getElementById('petals-container');
    const petal = document.createElement('div');
    petal.className = 'petal';
    const petals = ['🌸', '🌼', '💮', '✿', '❀'];
    petal.textContent = petals[Math.floor(Math.random() * petals.length)];
    petal.style.left = Math.random() * 100 + '%';
    petal.style.fontSize = (Math.random() * 16 + 12) + 'px';
    petal.style.animationDuration = (Math.random() * 6 + 6) + 's';
    petal.style.animationDelay = Math.random() * 2 + 's';
    container.appendChild(petal);
    setTimeout(() => petal.remove(), 14000);
  }
  setInterval(createPetal, 800);

  // Sparkles
  function createSparkles() {
    const container = document.getElementById('sparkles-container');
    for (let i = 0; i < 15; i++) {
      const dot = document.createElement('div');
      dot.className = 'sparkle-dot';
      dot.style.left = Math.random() * 100 + '%';
      dot.style.top = Math.random() * 100 + '%';
      dot.style.background = ['#FFB6C1', '#F5A623', '#98D8AA', '#FFE4B5'][Math.floor(Math.random() * 4)];
      dot.style.animationDelay = Math.random() * 3 + 's';
      container.appendChild(dot);
    }
  }
  createSparkles();

  // Surprise Button
  let surpriseCount = 0;
  const surprises = [
    "You're the brightest sunflower in my garden! 🌻",
    "Every day with you blooms with joy! 🌷",
    "You make the world more colorful! 🌈",
    "Here's a virtual hug! 🤗💐",
    "You're one in 7.8 billion! ⭐",
    "Life is sweeter because of you! 🍰",
    "You're my favourite notification! 📱💕",
    "Plot twist: you're amazing! ✨"
  ];

  function triggerSurprise() {
    surpriseCount++;
    const btn = document.getElementById('surprise-btn');
    const msg = surprises[(surpriseCount - 1) % surprises.length];

    // Create popup
    const popup = document.createElement('div');
    popup.className = 'pop-in fixed z-50 flex items-center justify-center';
    popup.style.cssText = 'top: 50%; left: 50%; transform: translate(-50%, -50%); padding: 2rem 3rem; border-radius: 1.5rem; background: white; box-shadow: 0 20px 60px rgba(212,103,142,0.3); max-width: 90vw;';
    popup.innerHTML = `
      <div class="text-center">
        <p class="text-4xl mb-4">🎉🌸🎉</p>
        <p class="text-xl font-bold" style="color: #D4678E; font-family: 'Playfair Display', serif;">${msg}</p>
        <button onclick="this.parentElement.parentElement.remove()" class="mt-4 px-6 py-2 rounded-full text-white font-semibold" style="background: linear-gradient(135deg, #FFB6C1, #F5A623);">Yay! 🌼</button>
      </div>
    `;
    document.body.appendChild(popup);

    // Burst confetti
    for (let i = 0; i < 20; i++) {
      setTimeout(() => {
        const conf = document.createElement('div');
        conf.style.cssText = `position: fixed; z-index: 60; left: 50%; top: 50%; font-size: ${Math.random()*20+14}px; pointer-events: none; transition: all 1.5s ease-out;`;
        conf.textContent = ['🌸','🌼','💛','✨','🌺','💕','🌷'][Math.floor(Math.random()*7)];
        document.body.appendChild(conf);
        requestAnimationFrame(() => {
          conf.style.left = (50 + (Math.random()-0.5)*80) + '%';
          conf.style.top = (50 + (Math.random()-0.5)*80) + '%';
          conf.style.opacity = '0';
        });
        setTimeout(() => conf.remove(), 1600);
      }, i * 50);
    }
  }

  // Flower Garden
  const gardenFlowers = [
    { emoji: '🌸', msg: "You're blooming wonderful!" },
    { emoji: '🌻', msg: "You light up every room!" },
    { emoji: '🌷', msg: "Elegant, just like you!" },
    { emoji: '🌼', msg: "Bright and cheerful, that's you!" },
    { emoji: '🌺', msg: "Bold and beautiful!" },
    { emoji: '💐', msg: "A whole bouquet of love!" },
    { emoji: '🪻', msg: "Rare and precious!" },
    { emoji: '🌹', msg: "Classic and timeless!" },
    { emoji: '💮', msg: "Pure joy!" },
    { emoji: '🪷', msg: "Calm and serene!" }
  ];

  function buildGarden() {
    const container = document.getElementById('flower-garden');
    gardenFlowers.forEach((f, i) => {
      const el = document.createElement('div');
      el.className = 'garden-flower text-4xl md:text-5xl';
      el.style.animationDelay = (i * 0.1) + 's';
      el.textContent = f.emoji;
      el.onclick = () => showFlowerMessage(f.msg);
      container.appendChild(el);
    });
  }

  function showFlowerMessage(msg) {
    const el = document.getElementById('flower-message');
    el.style.opacity = '1';
    el.querySelector('p').textContent = msg;
    setTimeout(() => { el.style.opacity = '0'; }, 3000);
  }
  buildGarden();

  // Wish Cards
  const wishes = [
    "May this year bring you endless adventures! 🗺️",
    "Wishing you laughter that echoes forever! 😄",
    "May all your wildest dreams take flight! 🦋",
    "Here's to more unforgettable memories! 📸",
    "May you always stay as amazing as you are! 💫"
  ];

  function buildWishes() {
    const container = document.getElementById('wish-cards');
    wishes.forEach((w, i) => {
      const card = document.createElement('div');
      card.className = 'p-5 rounded-2xl text-left transition-all duration-300 hover:scale-105 cursor-default';
      card.style.cssText = `background: rgba(255,255,255,0.8); backdrop-filter: blur(5px); border-left: 4px solid ${i%2===0 ? '#FFB6C1' : '#F5A623'}; animation: pop-in 0.5s ${i*0.15}s both;`;
      card.innerHTML = `<p class="font-semibold" style="color: #555;">${w}</p>`;
      container.appendChild(card);
    });
  }
  buildWishes();

  // Bouquet Maker
  let bouquetFlowers = [];

  function addToVase(btn) {
    const flower = btn.dataset.flower;
    bouquetFlowers.push(flower);
    updateVaseDisplay();
    
    // Animate button click
    btn.style.transform = 'scale(0.9)';
    setTimeout(() => btn.style.transform = 'scale(1)', 150);
  }

  function updateVaseDisplay() {
    const display = document.getElementById('flowers-display');
    display.innerHTML = '';
    
    bouquetFlowers.forEach((f, i) => {
      const flowerEl = document.createElement('div');
      flowerEl.className = 'pop-in';
      flowerEl.style.cssText = `font-size: ${Math.random() * 8 + 24}px; animation-delay: ${i * 0.05}s; cursor: pointer; transition: transform 0.2s;`;
      flowerEl.textContent = f;
      flowerEl.onmouseover = () => flowerEl.style.transform = 'scale(1.2) rotate(10deg)';
      flowerEl.onmouseout = () => flowerEl.style.transform = 'scale(1)';
      flowerEl.onclick = () => removeBouquetFlower(i);
      display.appendChild(flowerEl);
    });

    document.getElementById('flower-count').textContent = bouquetFlowers.length;
    document.getElementById('flower-text').textContent = bouquetFlowers.length === 1 ? 'flower' : 'flowers';
  }

  function removeBouquetFlower(index) {
    bouquetFlowers.splice(index, 1);
    updateVaseDisplay();
  }

  function clearVase() {
    bouquetFlowers = [];
    updateVaseDisplay();
  }

  function saveBouquet() {
    if (bouquetFlowers.length === 0) {
      alert('Add some flowers first! 🌸');
      return;
    }

    const popup = document.createElement('div');
    popup.className = 'pop-in fixed z-50 flex items-center justify-center';
    popup.style.cssText = 'top: 50%; left: 50%; transform: translate(-50%, -50%); padding: 2rem 3rem; border-radius: 1.5rem; background: white; box-shadow: 0 20px 60px rgba(212,103,142,0.3); max-width: 90vw;';
    popup.innerHTML = `
      <div class="text-center">
        <p class="text-3xl mb-4">${bouquetFlowers.join(' ')}</p>
        <p class="text-lg font-bold mb-4" style="color: #D4678E; font-family: 'Playfair Display', serif;">Your bouquet is perfect! 💕</p>
        <button onclick="this.parentElement.parentElement.remove()" class="px-6 py-2 rounded-full text-white font-semibold" style="background: linear-gradient(135deg, #FFB6C1, #F5A623);">Love It! 🌸</button>
      </div>
    `;
    document.body.appendChild(popup);
  }

  // Love Counter
  let loveCount = 0;
  function sendLove() {
    loveCount++;
    document.getElementById('love-count').textContent = `${loveCount} love${loveCount > 1 ? 's' : ''} sent`;

    const container = document.getElementById('hearts-fly');
    const heart = document.createElement('div');
    heart.className = 'heart-pop';
    heart.style.left = (Math.random() * 80 + 10) + '%';
    heart.style.top = (Math.random() * 80) + '%';
    heart.style.fontSize = (Math.random() * 20 + 16) + 'px';
    heart.textContent = ['💕', '💖', '💗', '💝', '❤️'][Math.floor(Math.random() * 5)];
    container.appendChild(heart);
    setTimeout(() => heart.remove(), 1000);
  }

  // Scroll reveal
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) e.target.classList.add('visible');
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.section-reveal').forEach(el => observer.observe(el));

  lucide.createIcons();
</script>
